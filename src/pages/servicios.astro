---
// src/pages/servicios.astro
import { Image } from 'astro:assets';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import imgDesarrollo from '../assets/icon-desarrollo.jpeg';
import imgIa from '../assets/icon-ia-negro.png';
import imgMarketing from '../assets/icon-marketing.jpeg';
import imgAds from '../assets/icon-ads-negro.png';
import imgBranding from '../assets/icon-branding.jpeg';
---

<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Servicios | Unanimous Growth</title>
    <style>html{background-color:#0D0D12}</style>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
</head>
<body>

    <Header initialTheme="dark" logoHref="/" />

    <header id="inicio-servicios" class="fullscreen-section hero-section dark-section">
        <div class="mesh-background">
            <canvas id="tech-canvas"></canvas>
            <div class="mesh-orb orb-1"></div>
            <div class="mesh-orb orb-2"></div>
            <div class="mesh-orb orb-3"></div>
        </div>
        <div class="content-wrapper text-center relative-layer animate-up">
            <h1 class="title-serif-huge">Nuestras Soluciones</h1>
            <p class="hero-subtitle" style="max-width: 800px; margin: 0 auto;">
                Estrategia, tecnología y visión para escalar tu negocio al siguiente nivel.
            </p>
        </div>
        
        <a href="#desarrollo" class="scroll-down-btn relative-layer" aria-label="Bajar">
            <svg viewBox="0 0 24 24" width="36" height="36" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </a>
    </header>

    <section id="desarrollo" class="fullscreen-section cream-section">
        <div class="content-wrapper split-layout">
            <div class="text-block animate-left">
                <h2>Desarrollo web profesional</h2>
                <p>Vamos más allá de crear páginas web. Construimos herramientas a la medida, optimizadas para la conversión y diseñadas para reflejar la identidad premium de tu negocio. Cada sitio es una máquina de ventas que trabaja 24/7.</p>
                <ul class="feature-list">
                    <li><span class="feat-name">✓ Landing page (una página)</span><span class="feat-price">$2,000–$2,500</span></li>
                    <li><span class="feat-name">✓ Sitio web corporativo</span><span class="feat-price">$3,500–$4,500</span></li>
                    <li><span class="feat-name">✓ Tienda en línea (E-commerce)</span><span class="feat-price">$8,000–$12,000</span></li>
                    <li><span class="feat-name">✓ Optimización de velocidad y SEO</span><span class="feat-price">$1,500–$2,500</span></li>
                    <li class="feat-note">ℹ️ Hosting, dominio &amp; mantenimiento trimestral +$1,000 · Ajustes desde $700 (pago único)</li>
                </ul>
                <a href="https://wa.me/528449102095?text=Hola,%20me%20interesa%20cotizar%20un%20servicio%20de%20Desarrollo%20Web." target="_blank" class="btn-primary mt-4">Cotizar Servicio</a>
            </div>
            <div class="icon-block animate-right icon-floating">
                <Image src={imgDesarrollo} alt="Desarrollo Web" class="service-img" />
            </div>
        </div>
        
        <a href="#ia" class="scroll-down-btn dark-btn" aria-label="Bajar">
            <svg viewBox="0 0 24 24" width="36" height="36" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </a>
    </section>

    <section id="ia" class="fullscreen-section dark-section">
        <div class="content-wrapper split-layout reverse">
            <div class="text-block animate-right">
                <h2>Automatización e Inteligencia Artificial</h2>
                <p>Eliminamos los cuellos de botella operativos integrando IA en tus procesos diarios. Reducimos el trabajo manual para que tu equipo se concentre en cerrar tratos y escalar la empresa.</p>
                <ul class="feature-list">
                    <li><span class="feat-name">✓ Chatbot WhatsApp 24/7</span><span class="feat-price">$3,000 + $400/mes</span></li>
                    <li><span class="feat-name">✓ Asistente / Cerrador Inteligente CRM</span><span class="feat-price">$11,000 + $1,000/mes</span></li>
                    <li><span class="feat-name">✓ Recepcionista Telefónica IA 24/7</span><span class="feat-price">$15,000 + $4,000/mes</span></li>
                    <li class="feat-note">ℹ️ Recepcionista incluye 500 min/mes · Minuto extra a $4 MXN</li>
                </ul>
                <a href="https://wa.me/528449102095?text=Hola,%20me%20interesa%20implementar%20Inteligencia%20Artificial%20en%20mi%20negocio." target="_blank" class="btn-primary mt-4">Cotizar Servicio</a>
            </div>
            <div class="icon-block animate-left icon-floating" style="animation-delay: 1s;">
                <Image src={imgIa} alt="Inteligencia Artificial" class="service-img" />
            </div>
        </div>
        
        <a href="#marketing" class="scroll-down-btn" aria-label="Bajar">
            <svg viewBox="0 0 24 24" width="36" height="36" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </a>
    </section>

    <section id="marketing" class="fullscreen-section cream-section">
        <div class="content-wrapper split-layout">
            <div class="text-block animate-left">
                <h2>Marketing Digital Estratégico</h2>
                <p>No publicamos por publicar. Desarrollamos planes de contenido y gestión estratégica enfocados en posicionar tu marca, crear autoridad en tu nicho y atraer a tu cliente ideal.</p>
                <ul class="feature-list">
                    <li><span class="feat-name">✓ Gestión de redes sociales</span><span class="feat-price">$3,500–$8,000/mes</span></li>
                    <li><span class="feat-name">✓ Estrategia de contenido</span><span class="feat-price">$2,000–$5,000 único</span></li>
                    <li><span class="feat-name">✓ Email marketing &amp; retención</span><span class="feat-price">Setup $2,500–$6,000</span></li>
                    <li><span class="feat-name">✓ Análisis de métricas y crecimiento</span><span class="feat-price">$1,000–$3,000/mes</span></li>
                </ul>
                <a href="https://wa.me/528449102095?text=Hola,%20quiero%20informaci%C3%B3n%20sobre%20Marketing%20Digital%20Estrat%C3%A9gico." target="_blank" class="btn-primary mt-4">Cotizar Servicio</a>
            </div>
            <div class="icon-block animate-right icon-floating" style="animation-delay: 0.5s;">
                <Image src={imgMarketing} alt="Marketing Digital" class="service-img" />
            </div>
        </div>

        <a href="#ads" class="scroll-down-btn dark-btn" aria-label="Bajar">
            <svg viewBox="0 0 24 24" width="36" height="36" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </a>
    </section>

    <section id="ads" class="fullscreen-section dark-section">
        <div class="content-wrapper split-layout reverse">
            <div class="text-block animate-right">
                <h2>Publicidad Digital (Ads)</h2>
                <p>Campañas publicitarias altamente segmentadas y optimizadas para el retorno de inversión (ROI). Hacemos que cada peso invertido se traduzca en prospectos calificados listos para comprar.</p>
                <ul class="feature-list">
                    <li><span class="feat-name">✓ Campañas Meta Ads (gestión)</span><span class="feat-price">$4,000–$6,000/mes</span></li>
                    <li><span class="feat-name">✓ Google Ads (búsqueda y display)</span><span class="feat-price">Setup $2,500–$5,000</span></li>
                    <li><span class="feat-name">✓ Retargeting recuperación de carritos</span><span class="feat-price">$1,500–$4,000</span></li>
                    <li><span class="feat-name">✓ Embudos de venta automatizados</span><span class="feat-price">$5,000–$15,000</span></li>
                </ul>
                <a href="https://wa.me/528449102095?text=Hola,%20me%20interesa%20lanzar%20campa%C3%B1as%20de%20Publicidad%20Digital%20(Ads)." target="_blank" class="btn-primary mt-4">Cotizar Servicio</a>
            </div>
            <div class="icon-block animate-left icon-floating" style="animation-delay: 1.5s;">
                <Image src={imgAds} alt="Publicidad Digital Ads" class="service-img" />
            </div>
        </div>

        <a href="#branding" class="scroll-down-btn" aria-label="Bajar">
            <svg viewBox="0 0 24 24" width="36" height="36" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </a>
    </section>

    <section id="branding" class="fullscreen-section cream-section">
        <div class="content-wrapper split-layout">
            <div class="text-block animate-left">
                <h2>Branding e Identidad de Marca</h2>
                <p>Una marca sólida genera confianza inmediata. Diseñamos identidades visuales que transmiten tu filosofía corporativa y te diferencian drásticamente de tu competencia.</p>
                <ul class="feature-list">
                    <li><span class="feat-name">✓ Branding Corporativo Básico</span><span class="feat-price">$3,000–$5,000</span></li>
                    <li><span class="feat-name">✓ Logotipo e imagotipo</span><span class="feat-price">$3,000–$10,000</span></li>
                    <li><span class="feat-name">✓ Manual de Identidad Corporativa</span><span class="feat-price">$3,000–$8,000</span></li>
                    <li><span class="feat-name">✓ Paleta de color y tipografía</span><span class="feat-price">$1,500–$3,000</span></li>
                    <li><span class="feat-name">✓ Papelería y aplicaciones digitales</span><span class="feat-price">$1,500–$5,000</span></li>
                </ul>
                <a href="https://wa.me/528449102095?text=Hola,%20quiero%20cotizar%20un%20servicio%20de%20Branding%20e%20Identidad%20de%20Marca." target="_blank" class="btn-primary mt-4">Cotizar Servicio</a>
            </div>
            <div class="icon-block animate-right icon-floating" style="animation-delay: 0.8s;">
                <Image src={imgBranding} alt="Branding e Identidad" class="service-img" />
            </div>
        </div>

        <a href="#paquetes" class="scroll-down-btn dark-btn" aria-label="Bajar">
            <svg viewBox="0 0 24 24" width="36" height="36" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </a>
    </section>

    <section id="paquetes" class="fullscreen-section dark-section" style="height: auto; min-height: 100vh; padding-bottom: 120px;">
        <div class="content-wrapper text-center animate-up">
            <h2 class="title-serif-huge" style="margin-bottom: 2vh;">Paquetes Integrales</h2>
            <p style="max-width: 800px; margin: 0 auto 5vh auto; font-size: 1.2rem; color: #EFEFEF;">Desliza para descubrir nuestras soluciones diseñadas para generar impacto real y rentabilidad. Elige la etapa en la que se encuentra tu negocio.</p>
            
            <div class="pkg-swipe-hint" aria-hidden="true">
                <svg viewBox="0 0 40 18" width="40" height="18" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <line x1="2" y1="9" x2="38" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    <polyline points="30,2 38,9 30,16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>Desliza</span>
                <svg viewBox="0 0 40 18" width="40" height="18" fill="none" xmlns="http://www.w3.org/2000/svg" style="transform: scaleX(-1);">
                    <line x1="2" y1="9" x2="38" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    <polyline points="30,2 38,9 30,16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>

            <div class="packages-scroll-wrapper" id="pkg-scroll-wrapper">
                <div class="packages-grid" id="pkg-grid">

                    <div class="package-card highlighted pkg-animate" style="transition-delay: 0.1s;">
                        <div class="badge badge-star">Servicio Estrella</div>
                        <h3>Piloto Automático</h3>
                        <div class="price-tag">Instalación $4,900 <span>MXN</span></div>
                        <div class="price-sub">+ mensualidad desde $600 MXN</div>
                        <p class="package-desc" style="margin-bottom: 0;">Tu negocio responde y genera oportunidades 24/7 de forma automática, convirtiendo cada mensaje, incluso fuera de horario, en una oportunidad de venta.</p>
                        <ul class="package-features text-left">
                            <li>✓ Página Web Completa</li>
                            <li>✓ Sistema de Atención 24/7 (WhatsApp)</li>
                            <li>✓ Automatización inteligente</li>
                        </ul>
                        <a href="https://wa.me/528449102095?text=Hola,%20me%20interesa%20el%20Paquete%20Piloto%20Autom%C3%A1tico." target="_blank" class="btn-primary mt-4">Cotizar Paquete</a>
                    </div>

                    <div class="package-card pkg-animate diamond-card" style="transition-delay: 0.3s;">
                        <div class="badge badge-diamond">Diamond 💎</div>
                        <h3 style="color: #fff;">Unanimous Enterprise</h3>
                        <div class="price-tag">$25,000 – $35,000 <span>MXN</span></div>
                        <div class="price-sub">Mantenimiento 2 meses incluido · 3er mes $3,500/mes</div>
                        <p class="package-desc">Evoluciona tu empresa con una transformación digital moderna y de alta gama, implementando automatización inteligente 24/7 que optimiza procesos, potencia ventas y eleva tu operación a nivel profesional.</p>
                        <ul class="package-features text-left">
                            <li>✓ Branding Corporativo de Alta Gama</li>
                            <li>✓ Web Avanzada &amp; SEO Estratégico</li>
                            <li>✓ Recepcionista Telefónica IA 24/7</li>
                            <li>✓ Cerrador Inteligente WhatsApp &amp; CRM</li>
                        </ul>
                        <a href="https://wa.me/528449102095?text=Hola,%20me%20interesa%20el%20Paquete%20Unanimous%20Enterprise%20(Diamond)." target="_blank" class="btn-primary btn-diamond mt-4">Cotizar Paquete</a>
                    </div>

                    <div class="package-card pkg-animate" style="transition-delay: 0.5s;">
                        <div class="badge badge-normal">Gold</div>
                        <h3>The Growth</h3>
                        <div class="price-tag">$7,500 – $11,500 <span>MXN / mes</span></div>
                        <div class="price-sub">&nbsp;</div>
                        <p class="package-desc">Diseñado para empresas con flujo constante que buscan acelerar sus ventas y consolidar su posición en el mercado.</p>
                        <ul class="package-features text-left">
                            <li>✓ Campañas en Meta Ads</li>
                            <li>✓ Manejo de Redes Sociales</li>
                            <li>✓ Automatización total de ventas</li>
                            <li>✓ Branding</li>
                        </ul>
                        <a href="https://wa.me/528449102095?text=Hola,%20me%20interesa%20el%20Paquete%20The%20Growth." target="_blank" class="btn-primary mt-4">Cotizar Paquete</a>
                    </div>

                    <div class="package-card pkg-animate" style="transition-delay: 0.7s;">
                        <div class="badge badge-normal">Servicio Basico</div>
                        <h3>Paquete Presencia</h3>
                        <div class="price-tag">$2,500 – $3,500 <span>MXN</span></div>
                        <div class="price-sub">+ mensualidad desde $400 MXN</div>
                        <p class="package-desc">Haz que tu negocio arranque en internet de forma profesional y segura. Ideal para establecer una presencia clara y estratégica, lista para convertir visitantes en clientes.</p>
                        <ul class="package-features text-left">
                            <li>✓ Landing page profesional (una sola página)</li>
                            <li>✓ Dominio personalizado (.com.mx, etc.)</li>
                            <li>✓ Hosting incluido</li>
                            <li>✓ Botón directo a WhatsApp</li>
                        </ul>
                        <a href="https://wa.me/528449102095?text=Hola,%20me%20interesa%20el%20Paquete%20Presencia." target="_blank" class="btn-primary mt-4">Cotizar Paquete</a>
                    </div>

                    <div class="package-card pkg-animate" style="transition-delay: 0.9s;">
                        <div class="badge badge-normal">A Tu Medida</div>
                        <h3>Ecosistema Personalizado</h3>
                        <div class="price-tag">Cotización a medida</div>
                        <div class="price-sub">Adaptable a tu presupuesto</div>
                        <p class="package-desc">Construimos una arquitectura digital milimétrica para las metas únicas de tu empresa. Tú eliges qué necesitas, nosotros armamos la máquina.</p>
                        <ul class="package-features text-left">
                            <li>✓ Auditoría y diagnóstico inicial</li>
                            <li>✓ Soluciones 100% flexibles</li>
                            <li>✓ Escalable a tu propio ritmo</li>
                            <li>✓ Integración de servicios a elección</li>
                        </ul>
                        <a href="https://wa.me/528449102095?text=Hola,%20quiero%20cotizar%20un%20Ecosistema%20Personalizado." target="_blank" class="btn-primary mt-4">Cotizar Proyecto</a>
                    </div>

                </div>
            </div>
        </div>

        <a href="#inicio-servicios" class="scroll-down-btn" aria-label="Subir al inicio" style="position: absolute; bottom: 3vh;">
            <svg style="transform: rotate(180deg);" viewBox="0 0 24 24" width="36" height="36" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </a>
    </section>

    <Footer />

    <a href="https://wa.me/528449102095?text=Hola%20Unanimous%20Growth,%20estaba%20viendo%20su%20p%C3%A1gina%20web%20y%20me%20gustar%C3%ADa%20platicar%20sobre%20un%20proyecto." target="_blank" class="whatsapp-float">
        <svg viewBox="0 0 32 32" width="34" height="34" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M16.002 2.05A13.91 13.91 0 0 0 2.096 15.96c0 2.45.635 4.84 1.84 6.95L2 29.91l7.16-1.875a13.92 13.92 0 0 0 6.842 1.785h.005A13.912 13.912 0 0 0 29.912 15.96 13.913 13.913 0 0 0 16.002 2.05zm0 23.366a11.536 11.536 0 0 1-5.875-1.6l-.42-.25-4.364 1.144 1.164-4.25-.274-.436A11.532 11.532 0 0 1 4.453 15.96a11.554 11.554 0 0 1 11.55-11.554 11.554 11.554 0 0 1 11.553 11.555 11.554 11.554 0 0 1-11.554 11.455zm6.336-8.663c-.347-.174-2.05-1.013-2.368-1.13-.318-.115-.55-.173-.78.174-.23.346-.897 1.128-1.098 1.36-.2.23-.404.26-.75.086-.347-.173-1.464-.54-2.79-1.724-1.03-1.03-1.725-2.305-1.927-2.652-.202-.347-.022-.535.152-.708.156-.155.347-.404.52-.606.174-.203.232-.347.347-.578.116-.23.058-.433-.028-.606-.087-.173-.78-1.88-1.07-2.574-.28-.675-.568-.583-.78-.594-.2-.01-.432-.012-.663-.012a1.27 1.27 0 0 0-.925.433c-.318.347-1.214 1.186-1.214 2.89s1.243 3.352 1.416 3.583c.174.23 2.44 3.73 5.91 5.23 2.835 1.226 3.468 1.13 4.103 1.07.636-.057 2.05-.838 2.34-1.648.29-.81.29-1.503.203-1.648-.087-.145-.318-.23-.665-.405z"/></svg>
    </a>

    <script>
        document.addEventListener('DOMContentLoaded', () => {

            /* ── Canvas: red de partículas Tech/IA ── */
            const canvas = document.getElementById('tech-canvas') as HTMLCanvasElement;
            if (canvas) {
                const ctx = canvas.getContext('2d')!;
                let W = canvas.width = canvas.offsetWidth;
                let H = canvas.height = canvas.offsetHeight;

                const PARTICLE_COUNT = Math.min(55, Math.floor(W / 20));
                const MAX_DIST = 140;
                const particles: { x: number; y: number; vx: number; vy: number; r: number }[] = [];

                for (let i = 0; i < PARTICLE_COUNT; i++) {
                    particles.push({
                        x: Math.random() * W, y: Math.random() * H,
                        vx: (Math.random() - 0.5) * 0.35,
                        vy: (Math.random() - 0.5) * 0.35,
                        r: Math.random() * 1.5 + 0.5,
                    });
                }

                function draw() {
                    ctx.clearRect(0, 0, W, H);
                    // dots
                    for (const p of particles) {
                        ctx.beginPath();
                        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
                        ctx.fillStyle = 'rgba(160,140,255,0.55)';
                        ctx.fill();
                        // move
                        p.x += p.vx; p.y += p.vy;
                        if (p.x < 0 || p.x > W) p.vx *= -1;
                        if (p.y < 0 || p.y > H) p.vy *= -1;
                    }
                    // connections
                    for (let i = 0; i < particles.length; i++) {
                        for (let j = i + 1; j < particles.length; j++) {
                            const dx = particles[i].x - particles[j].x;
                            const dy = particles[i].y - particles[j].y;
                            const dist = Math.sqrt(dx * dx + dy * dy);
                            if (dist < MAX_DIST) {
                                const alpha = (1 - dist / MAX_DIST) * 0.18;
                                ctx.beginPath();
                                ctx.moveTo(particles[i].x, particles[i].y);
                                ctx.lineTo(particles[j].x, particles[j].y);
                                ctx.strokeStyle = `rgba(120,100,240,${alpha})`;
                                ctx.lineWidth = 0.8;
                                ctx.stroke();
                            }
                        }
                    }
                    requestAnimationFrame(draw);
                }
                draw();

                window.addEventListener('resize', () => {
                    W = canvas.width = canvas.offsetWidth;
                    H = canvas.height = canvas.offsetHeight;
                }, { passive: true });
            }

            /* ── Observer principal: service sections ── */
            const animElements = document.querySelectorAll('.animate-up, .animate-left, .animate-right');
            const animObserver = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                        observer.unobserve(entry.target);
                    }
                });
            }, { root: null, threshold: 0.12 });
            animElements.forEach(el => animObserver.observe(el));

            /* ── Observer de paquetes: dispara TODOS simultáneamente ── */
            const pkgWrapper = document.querySelector('.packages-scroll-wrapper');
            if (pkgWrapper) {
                const pkgObserver = new IntersectionObserver((entries, observer) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            pkgWrapper.classList.add('pkg-visible');
                            observer.unobserve(entry.target);
                        }
                    });
                }, { root: null, threshold: 0.08 });
                pkgObserver.observe(pkgWrapper);
            }

            /* ── CENTER-ACTIVE: glow the centered card on touch devices ── */
            const pkgScrollWrapper = document.getElementById('pkg-scroll-wrapper') as HTMLElement | null;
            if (pkgScrollWrapper && window.matchMedia('(hover: none)').matches) {
                const cards = Array.from(pkgScrollWrapper.querySelectorAll<HTMLElement>('.package-card'));

                function activateCenterCard() {
                    const wrapperRect = pkgScrollWrapper!.getBoundingClientRect();
                    const wrapperCenterX = wrapperRect.left + wrapperRect.width / 2;

                    let closestCard: HTMLElement | null = null;
                    let closestDist = Infinity;

                    cards.forEach(card => {
                        const rect = card.getBoundingClientRect();
                        const cardCenterX = rect.left + rect.width / 2;
                        const dist = Math.abs(cardCenterX - wrapperCenterX);
                        if (dist < closestDist) {
                            closestDist = dist;
                            closestCard = card;
                        }
                    });

                    cards.forEach(card => card.classList.remove('is-active'));
                    if (closestCard) (closestCard as HTMLElement).classList.add('is-active');
                }

                pkgScrollWrapper.addEventListener('scroll', activateCenterCard, { passive: true });
                window.addEventListener('resize', activateCenterCard, { passive: true });
                activateCenterCard(); // activate first card on load
            }

        });
    </script>

</body>
</html>

