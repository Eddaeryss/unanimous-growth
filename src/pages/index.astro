        <svg class="star desktop-only" style="bottom: 25%; left: 5%; transform: rotate(-10deg);" viewBox="0 0 100 100" width="30"><path d="M50 0 C50 40 60 50 100 50 C60 50 50 60 50 100 C50 60 40 50 0 50 C40 50 50 40 50 0 Z" fill="#000"/></svg>

        <div class="content-wrapper text-center compact-layout">
            <div class="gsap-section">
