    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // ── Efecto Malla Canvas Tech (Hero) ──
            const canvas = document.getElementById('tech-canvas') as HTMLCanvasElement;
            if (canvas) {
                const ctx = canvas.getContext('2d')!;
                let W = canvas.width = canvas.offsetWidth;
                let H = canvas.height = canvas.offsetHeight;

                const PARTICLE_COUNT = Math.min(55, Math.floor(W / 20));
                const MAX_DIST = 140;
                const particles: { x: number; y: number; vx: number; vy: number; r: number }[] = [];

                for (let i = 0; i < PARTICLE_COUNT; i++) {
                    particles.push({
                        x: Math.random() * W, y: Math.random() * H,
                        vx: (Math.random() - 0.5) * 0.35,
                        vy: (Math.random() - 0.5) * 0.35,
                        r: Math.random() * 1.5 + 0.5,
                    });
                }

                function draw() {
                    ctx.clearRect(0, 0, W, H);
                    // dots
                    for (const p of particles) {
                        ctx.beginPath();
                        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
                        ctx.fillStyle = 'rgba(160,140,255,0.55)';
                        ctx.fill();
                        // move
                        p.x += p.vx; p.y += p.vy;
                        if (p.x < 0 || p.x > W) p.vx *= -1;
                        if (p.y < 0 || p.y > H) p.vy *= -1;
                    }
                    // lines
                    for (let i = 0; i < PARTICLE_COUNT; i++) {
                        for (let j = i + 1; j < PARTICLE_COUNT; j++) {
                            const dx = particles[i].x - particles[j].x;
                            const dy = particles[i].y - particles[j].y;
                            const dist = Math.sqrt(dx * dx + dy * dy);
                            if (dist < MAX_DIST) {
                                ctx.beginPath();
                                ctx.moveTo(particles[i].x, particles[i].y);
                                ctx.lineTo(particles[j].x, particles[j].y);
                                ctx.strokeStyle = `rgba(160,140,255,${0.2 * (1 - dist / MAX_DIST)})`;
                                ctx.stroke();
                            }
                        }
                    }
                    requestAnimationFrame(draw);
                }
                draw();

                window.addEventListener('resize', () => {
                    W = canvas.width = canvas.offsetWidth;
                    H = canvas.height = canvas.offsetHeight;
                });
            }

            gsap.registerPlugin(ScrollTrigger);

            gsap.fromTo(".gsap-hero", 
                { y: 50, opacity: 0 }, 
                { y: 0, opacity: 1, duration: 1.2, stagger: 0.2, ease: "power3.out", clearProps: "all" }
            );

            const scrollSections = document.querySelectorAll('.gsap-section');
            scrollSections.forEach((section) => {
                gsap.fromTo(section, 
                    { y: 50, opacity: 0 },
                    {
                        scrollTrigger: {
                            trigger: section,
                            start: "top 85%", 
                            toggleActions: "play none none reverse"
                        },
                        y: 0, opacity: 1, duration: 1, ease: "power3.out"
                    }
                );
            });

            gsap.fromTo(".gsap-stagger", 
                { y: 40, opacity: 0 },
                {
                    scrollTrigger: {
                        trigger: "#stagger-container", 
                        start: "top 92%",
                        once: true
                    },
                    y: 0, 
                    opacity: 1, 
                    duration: 0.75, 
                    stagger: 0.12,
                    ease: "power3.out",
                    clearProps: "transform"
                }
            );
        });
    </script>
</body>
</html>

<style is:global>
    :root {
        --color-black: #000000;
        --color-cream: #FAF9F5;
        --font-serif: 'Playfair Display', serif;
        --font-script: 'Great Vibes', cursive;
        --font-sans: 'Inter', sans-serif;
    }
    html { scroll-behavior: smooth; }
    body { margin: 0; padding: 0; font-family: var(--font-serif); background-color: #0D0D12; color: var(--color-cream); overflow-x: hidden; }
    h1, h2, h3, h4 { font-family: var(--font-serif); font-weight: 700; margin: 0; }
    p { font-family: var(--font-sans); }
    a { text-decoration: none; color: inherit; }
</style>

<style>
    .text-center { text-align: center; }

    /* ESTRUCTURA DE PANTALLAS */
    .fullscreen-section { height: 100vh; width: 100%; position: relative; box-sizing: border-box; overflow: hidden; }
    .align-center { display: flex; flex-direction: column; justify-content: center; align-items: center; padding-top: 80px; }
    .content-wrapper { max-width: 1200px; margin: 0 auto; padding: 0 2rem; position: relative; z-index: 2; width: 100%; box-sizing: border-box; }

    /* HERO */
    .relative-layer { position: relative; z-index: 2; }
    .mesh-background {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        z-index: 0; overflow: hidden;
        background-color: #0D0D12;
    }
    #tech-canvas { display: block; width: 100%; height: 100%; }
    .mesh-orb {
        position: absolute; border-radius: 50%; filter: blur(70px);
        mix-blend-mode: screen; z-index: -1; animation: floatOrb 15s ease-in-out infinite alternate;
    }
    .orb-1 { width: 300px; height: 300px; background: rgba(80, 50, 200, 0.4); top: -100px; left: -100px; animation-duration: 18s; }
    .orb-2 { width: 400px; height: 400px; background: rgba(30, 100, 255, 0.25); bottom: -150px; right: -100px; animation-duration: 22s; animation-direction: alternate-reverse; }
    .orb-3 { width: 250px; height: 250px; background: rgba(140, 80, 255, 0.3); top: 30%; left: 50%; transform: translateX(-50%); animation-duration: 25s; }

    @keyframes floatOrb {
        0%   { transform: translate(0, 0) scale(1); }
        50%  { transform: translate(30px, -40px) scale(1.1); }
        100% { transform: translate(-20px, 20px) scale(0.9); }
    }

    #inicio {
        background-color: #0D0D12;
    }
    
    .hero-section { 
        display: flex; 
