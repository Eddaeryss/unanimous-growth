---
/**
 * Footer.astro — Unanimous Growth
 * Minimalista, oscuro, elegante y ULTRA COMPACTO. Mobile-first.
 */
---

<footer id="contacto" class="ug-footer">

  <div class="ug-footer-inner">

    <div class="ug-footer-col ug-col-brand">
      <a href="/" aria-label="Unanimous Growth — Inicio" class="ug-footer-logo-link">
        <img
