      <p class="ug-footer-tagline">Crecemos juntos, con propósito y dirección.</p>
    </div>

    <div class="ug-footer-col ug-col-contact">
      <h4 class="ug-footer-heading">Contacto</h4>

      <ul class="ug-contact-list">
        <li>
          <svg class="ug-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
            <circle cx="12" cy="9" r="2.5"/>
          </svg>
          <span>Saltillo, Coahuila, México</span>
        </li>
        <li>
          <svg class="ug-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <polyline points="2,4 12,13 22,4"/>
          </svg>
          <a href="mailto:hola@unanimousgrowth.com">hola@unanimousgrowth.com</a>
        </li>
      </ul>

      <div class="ug-social-row">
        <a href="https://www.instagram.com/ungrowth_2026?igsh=NXdwYjVwNjV4azNo" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="ug-social-link">
          <svg class="ug-social-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5"/>
            <circle cx="12" cy="12" r="4.5"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
          </svg>
        </a>
        <a href="https://www.facebook.com/share/1ZsqZMVPdF/" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="ug-social-link">
          <svg class="ug-social-icon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>
        <a href="https://www.linkedin.com/company/unanimous-growth" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="ug-social-link">
          <svg class="ug-social-icon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>
        <a href="https://wa.me/528449102095?text=Hola,%20me%20interesa%20iniciar%20un%20proyecto." target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="ug-social-link">
          <svg class="ug-social-icon" viewBox="0 0 32 32" fill="currentColor">
            <path d="M16.002 2.05A13.91 13.91 0 0 0 2.096 15.96c0 2.45.635 4.84 1.84 6.95L2 29.91l7.16-1.875a13.92 13.92 0 0 0 6.842 1.785h.005A13.912 13.912 0 0 0 29.912 15.96 13.913 13.913 0 0 0 16.002 2.05zm0 23.366a11.536 11.536 0 0 1-5.875-1.6l-.42-.25-4.364 1.144 1.164-4.25-.274-.436A11.532 11.532 0 0 1 4.453 15.96a11.554 11.554 0 0 1 11.55-11.554 11.554 11.554 0 0 1 11.553 11.555 11.554 11.554 0 0 1-11.554 11.455zm6.336-8.663c-.347-.174-2.05-1.013-2.368-1.13-.318-.115-.55-.173-.78.174-.23.346-.897 1.128-1.098 1.36-.2.23-.404.26-.75.086-.347-.173-1.464-.54-2.79-1.724-1.03-1.03-1.725-2.305-1.927-2.652-.202-.347-.022-.535.152-.708.156-.155.347-.404.52-.606.174-.203.232-.347.347-.578.116-.23.058-.433-.028-.606-.087-.173-.78-1.88-1.07-2.574-.28-.675-.568-.583-.78-.594-.2-.01-.432-.012-.663-.012a1.27 1.27 0 0 0-.925.433c-.318.347-1.214 1.186-1.214 2.89s1.243 3.352 1.416 3.583c.174.23 2.44 3.73 5.91 5.23 2.835 1.226 3.468 1.13 4.103 1.07.636-.057 2.05-.838 2.34-1.648.29-.81.29-1.503.203-1.648-.087-.145-.318-.23-.665-.405z"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="ug-footer-col ug-col-links">
      <h4 class="ug-footer-heading">Navegación</h4>
      <ul class="ug-footer-nav">
        <li><a href="/#inicio">Inicio</a></li>
        <li><a href="/#unanimidad">Visión</a></li>
        <li><a href="/#nosotros">Nosotros</a></li>
        <li><a href="/servicios">Servicios</a></li>
        <li><a href="/#contacto">Contacto</a></li>
      </ul>
    </div>

  </div><div class="ug-footer-divider"></div>

  <div class="ug-footer-bottom">
    <p class="ug-copyright">© 2026 Unanimous Growth. Todos los derechos reservados.</p>
    <nav class="ug-legal-links" aria-label="Documentos legales">
      <a
        href="/legal#terminos"
        target="_blank"
        rel="noopener noreferrer"
        class="ug-legal-link"
      >Términos y Condiciones</a>
      <span class="ug-legal-sep" aria-hidden="true">·</span>
      <a
        href="/legal#privacidad"
        target="_blank"
        rel="noopener noreferrer"
        class="ug-legal-link"
      >Aviso de Privacidad</a>
    </nav>
  </div>

</footer>

<style>
  /* ─────────────────────────────────────────────────
     VARIABLES (heredadas del sistema global de UG)
     ───────────────────────────────────────────────── */
  :root {
    --ug-footer-bg:      #080810;
    --ug-footer-text:    #FAF9F5;
    --ug-footer-muted:   rgba(250, 249, 245, 0.55);
    --ug-footer-border:  rgba(250, 249, 245, 0.10);
    --ug-footer-accent:  rgba(160, 140, 255, 0.9);
    --ug-font-serif:     'Playfair Display', serif;
    --ug-font-sans:      'Inter', sans-serif;
  }

  /* ─── Contenedor base ─────────────────────────── */
  .ug-footer {
    background-color: var(--ug-footer-bg);
    color: var(--ug-footer-text);
    /* REDUCIDO AL MÁXIMO: 2rem arriba, 1rem abajo */
    padding: 2rem 2rem 1rem;
    width: 100%;
    box-sizing: border-box;
    border-top: 1px solid var(--ug-footer-border);
  }

  /* ─── Zona de 3 columnas ─────────────────────── */
  .ug-footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    /* REDUCIDO */
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .ug-footer-col {
    flex: 1;
    min-width: 220px;
  }

  /* ─── Col 1: Marca ───────────────────────────── */
  .ug-col-brand {
    display: flex;
    flex-direction: column;
    /* TEXTO PEGADO AL LOGO */
    gap: 0.25rem;
  }

  .ug-footer-logo-link {
    display: inline-block;
    line-height: 0;
  }

  .ug-footer-logo {
    /* LOGO MÁS COMPACTO */
    width: 130px;
    max-width: 100%;
    height: auto;
    mix-blend-mode: screen;
    object-fit: contain;
    display: block;
  }

  .ug-footer-tagline {
    font-family: var(--ug-font-sans);
    font-size: 0.85rem;
    font-style: italic;
    color: var(--ug-footer-muted);
    line-height: 1.5;
    margin: 0;
    max-width: 260px;
  }

  /* ─── Col 2: Contacto ────────────────────────── */
  .ug-footer-heading {
    font-family: var(--ug-font-serif);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--ug-footer-muted);
    /* ESPACIO MÍNIMO BAJO EL TÍTULO */
    margin: 0 0 0.5rem 0;
  }

  .ug-contact-list {
    list-style: none;
    padding: 0;
    /* REDUCIDO */
    margin: 0 0 0.75rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .ug-contact-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-family: var(--ug-font-sans);
    font-size: 0.85rem;
    color: var(--ug-footer-muted);
    line-height: 1.5;
  }

  .ug-contact-list a {
    color: var(--ug-footer-muted);
    text-decoration: none;
    transition: color 0.25s ease;
  }
  .ug-contact-list a:hover {
    color: var(--ug-footer-text);
  }

  .ug-icon {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    margin-top: 2px;
    opacity: 0.6;
  }

  /* ─── Redes sociales ─────────────────────────── */
  .ug-social-row {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .ug-social-link {
    color: var(--ug-footer-muted);
    transition: color 0.25s ease, transform 0.25s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ug-social-link:hover {
    color: var(--ug-footer-accent);
    transform: translateY(-3px);
  }

  .ug-social-icon {
    width: 18px;
    height: 18px;
    display: block;
  }

  /* ─── Col 3: Links ──────────────────────────── */
  .ug-footer-nav {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    /* REDUCIDO */
    gap: 0.3rem;
  }

  .ug-footer-nav a {
    font-family: var(--ug-font-sans);
    font-size: 0.85rem;
    color: var(--ug-footer-muted);
    text-decoration: none;
    transition: color 0.25s ease, padding-left 0.25s ease;
    display: inline-block;
  }

  .ug-footer-nav a:hover {
    color: var(--ug-footer-text);
    padding-left: 4px;
  }

  /* ─── Divisor ────────────────────────────────── */
  .ug-footer-divider {
    max-width: 1200px;
    /* ESPACIO SUPER REDUCIDO */
    margin: 1.25rem auto 0;
    border: none;
    border-top: 1px solid var(--ug-footer-border);
  }

  /* ─── Barra inferior ─────────────────────────── */
  .ug-footer-bottom {
    max-width: 1200px;
    /* ESPACIO SUPER REDUCIDO */
    margin: 0.75rem auto 0;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .ug-copyright {
    font-family: var(--ug-font-sans);
    font-size: 0.75rem;
    color: var(--ug-footer-muted);
    margin: 0;
    opacity: 0.7;
  }

  .ug-legal-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .ug-legal-link {
    font-family: var(--ug-font-sans);
    font-size: 0.75rem;
    color: var(--ug-footer-muted);
    text-decoration: none;
    transition: color 0.25s ease;
    opacity: 0.7;
  }

  .ug-legal-link:hover {
    color: var(--ug-footer-text);
    opacity: 1;
  }

  .ug-legal-sep {
    color: var(--ug-footer-border);
    font-size: 0.75rem;
  }

  /* ─────────────────────────────────────────────────
     RESPONSIVE
     ───────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .ug-footer {
      padding: 2rem 1.5rem 1rem;
    }

    .ug-footer-inner {
      flex-direction: column;
      gap: 1.5rem;
    }

    .ug-footer-col {
      min-width: unset;
      width: 100%;
    }

    .ug-footer-tagline {
      max-width: 100%;
    }

    .ug-footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.4rem;
    }
  }

  @media (max-width: 480px) {
    .ug-footer {
      padding: 1.5rem 1rem 1rem;
    }

    .ug-footer-logo {
      width: 110px;
    }
  }
</style>